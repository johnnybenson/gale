#!/usr/bin/env node

"use strict";

const { spawnSync } = require("child_process");
const os = require("os");

const PLATFORMS = {
  "darwin-arm64": "@aspect/gale-darwin-arm64/gale",
  "darwin-x64": "@aspect/gale-darwin-x64/gale",
  "linux-x64": "@aspect/gale-linux-x64/gale",
  "linux-arm64": "@aspect/gale-linux-arm64/gale",
  "win32-x64": "@aspect/gale-win32-x64/gale.exe",
};

function getGaleBinary() {
  // Allow override via environment variable
  const envBinary = process.env.GALE_BINARY;
  if (envBinary) {
    return envBinary;
  }

  const platform = `${os.platform()}-${os.arch()}`;
  const packagePath = PLATFORMS[platform];

  if (!packagePath) {
    console.error(
      `Gale does not support your platform yet: ${platform}.\n` +
        "You can set the GALE_BINARY environment variable to point to a Gale binary."
    );
    process.exit(1);
  }

  try {
    return require.resolve(packagePath);
  } catch {
    console.error(
      `Could not find the Gale binary for your platform (${platform}).\n` +
        "This likely means the optional dependency was not installed.\n\n" +
        "Try reinstalling with:\n" +
        "  bun install gale-lint\n\n" +
        "Or set the GALE_BINARY environment variable to point to a Gale binary."
    );
    process.exit(1);
  }
}

const binaryPath = getGaleBinary();
const args = process.argv.slice(2);
const result = spawnSync(binaryPath, args, { stdio: "inherit" });

if (result.error) {
  throw result.error;
}

process.exit(result.status ?? 1);
